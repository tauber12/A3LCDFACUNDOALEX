/*-----------------------------------------------------------------------------
 * function : Wait_for_4_User_Digits( )
 * INs      : lcd_In[4] - caller-allocated array to store 4 ASCII digit inputs
 * OUTs     : none (fills lcd_In[] in place)
 * action   : clears input array; loops until 4 valid digit inputs received;
 *            '*' resets count and re-prompts; '#' ignored during entry;
 *            updates LCD after each valid digit press; waits for key release
 *            before accepting next input; after 4 digits displays confirm
 *            prompt and disables blinking cursor
 * authors  : Alex Tauber
 * version  : 0.1
 * date     : 260415
 * usage    : called in STATE_ENTER_DIGITS; fills inputtedDigits[] for timer
 *----------------------------------------------------------------------------*/
void Wait_for_4_User_Digits(uint8_t lcd_In[4]){

	uint8_t press_Cnt = 0;    // track number of valid digit inputs received
	memset( lcd_In, 0, 4 );   // clear input array before collection begins

	while( press_Cnt < 4 ) {  // loop until all 4 digits received

		lcd_In[ press_Cnt ] = Return_ValidKeyPressLCD(); // block until valid keypress

		if( lcd_In[ press_Cnt ] == '*' ){

			/* '*' detected - reset collection and re-display entry prompt */
			press_Cnt = 0;
			memset( lcd_In, 0, 4 );
			Prompt_user_4_numbers();
			continue;

		} else if ( lcd_In[press_Cnt] == '#' ) {

			continue; // '#' ignored during digit entry

		} else {

			/* valid digit - store, update count, update LCD display */
			press_Cnt++;
			delay_us(1000);
			Update_entered_numbers( lcd_In, press_Cnt );

			/* after 2nd digit, reposition cursor to tens (sec) column */
			if( press_Cnt == 2 ){
				LCD_set_cursor(1, 14);
			}

			/* wait for key release before accepting next input (debounce) */
			while( Keypad_IsAnyKeyPressed() != 0 ){}

		}
	}

	/* all 4 digits received - display confirm prompt, disable blinking cursor */
	LCD_set_cursor(0, 0);
	LCD_write_string("# -> BEGIN      "); // line 1: confirm prompt
	LCD_set_cursor(1, 0);
	LCD_write_string("* -> RESET");       // line 2: reset option
	LCD_set_cursor(1, 16);
	LCD_command( 0xC );                   // display ON/OFF control: cursor OFF (D=1,C=0,B=0)

}

/*-----------------------------------------------------------------------------
 * function : Update_time( )
 * INs      : lcd_In[4] - array of 4 ASCII digit characters representing
 *                        current countdown time [MM tens, MM ones, SS tens, SS ones]
 * OUTs     : none
 * action   : writes all 4 countdown digits to correct LCD positions;
 *            ones (sec) at col 15, tens (sec) at col 14,
 *            ones (min) at col 12, tens (min) at col 11;
 *            small delays between writes for LCD stability
 * authors  : Alex Tauber
 * version  : 0.1
 * date     : 260415
 * usage    : called each iteration of STATE_TIMER after decrement logic
 *----------------------------------------------------------------------------*/
void Update_time(uint8_t lcd_In[4]){

	LCD_set_cursor(1, 15);          // ones (sec)
	LCD_write_char(lcd_In[3]);
	delay_us(500);
	LCD_set_cursor(1, 14);          // tens (sec)
	LCD_write_char(lcd_In[2]);
	delay_us(500);
	LCD_set_cursor(1, 12);          // ones (min)
	LCD_write_char(lcd_In[1]);
	delay_us(500);
	LCD_set_cursor(1, 11);          // tens (min)
	LCD_write_char(lcd_In[0]);

}
